generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  CLIENT
  ADMIN
}

enum OrderStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  PENDING_ADMIN_VALIDATION
  CONFIRMED
  IN_PREPARATION
  READY
  DELIVERING
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  AUTHORIZED
  CANCELLED
}

enum PaymentProvider {
  STRIPE
  CASH_ON_DELIVERY
}

enum DeliveryZoneType {
  RADIUS
  ZIP_CODES
  POLYGON
}

model User {
  id               String         @id @default(uuid())
  email            String         @unique
  password         String
  firstName        String?
  lastName         String?
  isDeleted        Boolean        @default(false)
  phone            String?
  role             UserRole       @default(CLIENT)
  stripeCustomerId String?
  activeZoneId     String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  addresses        Address[]
  cart             Cart?
  preferences      Preferences?
  orders           Order[]
  notifications    Notification[]
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   @default("INFO") // INFO, ORDER_UPDATE, PROMO
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Preferences {
  id             String   @id @default(uuid())
  userId         String   @unique
  pizzaFavorites String? // Could be JSON array string
  smsNotifs      Boolean  @default(false)
  emailNotifs    Boolean  @default(true)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Address {
  id           String   @id @default(uuid())
  street       String
  city         String
  zipCode      String
  instructions String?
  userId       String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders       Order[]
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  isDeleted Boolean   @default(false)
  products  Product[]
}

model Product {
  id          String      @id @default(uuid())
  name        String
  description String?
  price       Float
  categoryId  String
  available   Boolean     @default(true)
  isDeleted   Boolean     @default(false)
  images      String[]    @default([]) // Array of Cloudinary image URLs
  cartItems   CartItem[]
  orderItems  OrderItem[]
  category    Category    @relation(fields: [categoryId], references: [id])
}

model Topping {
  id                String             @id @default(uuid())
  name              String
  price             Float
  imageUrl          String?
  available         Boolean            @default(true)
  orderItemToppings OrderItemTopping[]
}

model Order {
  id              String         @id @default(uuid())
  userId          String?
  userType        String         @default("GUEST") // GUEST, REGISTERED
  total           Float
  deliveryFee     Float          @default(0)
  status          OrderStatus    @default(DRAFT)
  paymentStatus   PaymentStatus  @default(PENDING)
  paymentMethod   String         @default("CASH")
  paymentIntentId String?
  addressId       String?
  customerName    String?
  customerEmail   String?
  customerPhone   String?
  deliveryZoneId  String?

  // Time Slot Management
  isASAP        Boolean   @default(true)
  scheduledSlot String? // "14:30"
  scheduledDate DateTime? // Specific day for pre-orders

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  address      Address?        @relation(fields: [addressId], references: [id])
  deliveryZone DeliveryZone?   @relation(fields: [deliveryZoneId], references: [id])
  user         User?           @relation(fields: [userId], references: [id])
  items        OrderItem[]
  offers       OrderOfferItem[]
  payment      Payment?
}

model OrderItem {
  id        String             @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Float // Snapshot of product price
  name      String // Snapshot of product name
  product   Product            @relation(fields: [productId], references: [id])
  order     Order              @relation(fields: [orderId], references: [id])
  toppings  OrderItemTopping[]
}

model Offer {
  id          String           @id @default(uuid())
  name        String
  description String?
  price       Float
  available   Boolean          @default(true)
  isDeleted   Boolean          @default(false)
  images      String[]         @default([]) // Array of Cloudinary image URLs
  orderItems  OrderOfferItem[]
}

model OrderOfferItem {
  id       String @id @default(uuid())
  orderId  String
  offerId  String
  quantity Int
  price    Float // Snapshot of pack price including variations
  name     String // Snapshot of pack name
  options  String? // JSON storing the user's custom pack config (ingredients, drinks)
  offer    Offer  @relation(fields: [offerId], references: [id])
  order    Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OrderItemTopping {
  id          String    @id @default(uuid())
  orderItemId String
  toppingId   String
  name        String // Snapshot
  price       Float // Snapshot
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])
  topping     Topping   @relation(fields: [toppingId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String?
  userId    String?
  details   String? // JSON string
  createdAt DateTime @default(now())
}

model Payment {
  id             String          @id @default(uuid())
  orderId        String          @unique
  provider       PaymentProvider @default(STRIPE)
  transactionId  String?         @unique // Stripe PaymentIntent ID or similar
  amount         Float
  status         PaymentStatus   @default(PENDING)
  createdAt      DateTime        @default(now())
  order          Order           @relation(fields: [orderId], references: [id])
}

model DeliveryZone {
  id            String           @id @default(uuid())
  name          String           @unique
  fee           Float
  minOrder      Float
  estimatedTime Int
  isActive      Boolean          @default(true)
  type          DeliveryZoneType @default(RADIUS)
  radius        Float? // in km
  centerLat     Float?
  centerLng     Float?
  zipCodes      String? // comma separated list
  polygon       String? // JSON string of coordinates: [{"lat": 1, "lng": 2}, ...]
  orders        Order[]
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model Cart {
  id        String     @id @default(uuid())
  userId    String?    @unique
  updatedAt DateTime   @updatedAt
  user      User?      @relation(fields: [userId], references: [id])
  items     CartItem[]
}

model CartItem {
  id        String  @id @default(uuid())
  cartId    String
  productId String
  quantity  Int
  product   Product @relation(fields: [productId], references: [id])
  cart      Cart    @relation(fields: [cartId], references: [id])
}

model Settings {
  id              String   @id @default("global")
  restaurantName  String   @default("PIZZA HUB PREMIUM")
  contactEmail    String   @default("manager@pizzahub.com")
  restaurantAddress String  @default("15 Rue de la Paix, Paris")
  lat             Float    @default(48.8698)
  lng             Float    @default(2.3305)
  
  // Capacity & Timing
  minOrderValue   Float    @default(12.0)
  deliveryFee     Float    @default(0.0)
  preparationTime Int      @default(20) // base prep time in minutes
  deliveryTime    Int      @default(30) // base delivery time in minutes
  maxOrdersPerSlot Int     @default(5)  // max orders every 30 mins
  
  // Opening Hours (JSON string: {"mon": "11:00-23:00", ...})
  openingHours    String   @default("{\"mon\":\"11:00-23:00\",\"tue\":\"11:00-23:00\",\"wed\":\"11:00-23:00\",\"thu\":\"11:00-23:00\",\"fri\":\"11:00-00:00\",\"sat\":\"11:00-00:00\",\"sun\":\"11:00-23:00\"}")
  
  isOpen          Boolean  @default(true)
  updatedAt       DateTime @updatedAt
}
